{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A member of the church community",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the member" },
        "birthDate": { "type": "string", "format": "date", "description": "Date of birth" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Street address" },
        "neighborhood": { "type": "string", "description": "Neighborhood/Bairro" },
        "city": { "type": "string", "description": "City" },
        "maritalStatus": { "type": "string", "enum": ["Solteiro(a)", "Casado(a)", "Divorciado(a)", "Viúvo(a)"], "description": "Marital status" },
        "position": { "type": "string", "enum": ["Evangelista", "Presbítero", "Diácono", "Auxiliar", "Membro"], "description": "Ecclesiastical position" },
        "congregation": { "type": "string", "enum": ["Sede", "Jardim Caíc"], "description": "Local congregation" },
        "status": { "type": "string", "enum": ["Ativo", "Desligado"], "description": "Membership status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "createdBy": { "type": "string", "description": "UID of the user who created the record" }
      },
      "required": ["fullName", "birthDate", "phone", "congregation", "status"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members"
    }
  }
}
